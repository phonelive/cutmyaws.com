source 'https://rubygems.org'

gem 'bundler'

# Standard library gems required for Ruby 3.4+
gem 'json'
gem 'ostruct'
gem 'rexml'
gem 'uri'
gem 'net-http', require: 'net/http'
gem 'irb'

# AWS SDK — SSM for secrets, SES for email
gem 'aws-sdk-ssm'
gem 'aws-sdk-ses'

# MySQL/TiDB — Trilogy is a faster MySQL adapter for Ruby
gem 'trilogy'
gem 'activerecord', '~> 8.0.0', require: 'active_record'

# Timezone support
gem 'activesupport', require: 'active_support/all'

# Local development
gem 'webrick'
gem 'debug'
gem 'rake'

ruby '>= 3.4.0', '< 3.5.0'
